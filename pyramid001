#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n; // عدد الصفوف

    for(int i = 1; i <= n; i++) {
        // طباعة الفراغات (مثلث مقلوب)
        for(int j = 1; j <= n - i; j++) {
            cout << " ";
        }

        // طباعة النجوم
        for(int k = 1; k <= (2 * i - 1); k++) {
            cout << "*";
        }

        cout << endl;
    }

    return 0;
}
