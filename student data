#include <iostream>
using namespace std;
int main()
{
    string name ,ssn ,id ,pass;
    cin>>name>>ssn>>id>>pass;
    for(int i=0 ;i<ssn.size() ;i++){
        if(ssn.at(i)!='-'){
           ssn.at(i)='x';
        }
    }
     for(int j=0 ;j<pass.size() ;j++){
          pass.at(j)='x';
     }
     cout<<name<<" "<<ssn<<" "<<id<<" "<<pass;

    return 0;
}
