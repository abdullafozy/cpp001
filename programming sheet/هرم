#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    for(int i = 1; i <= n; i++) {
        
        // 1. طباعة المسافات لدفع النجوم للمنتصف
        for(int j = 1; j <= n - i; j++) {
            cout << " ";
        }

        // 2. نفس حلقتك بالضبط، لكن نطبع "* " (نجمة ثم مسافة)
        for(int j = 1; j <= i; j++) {
            cout << "* "; 
        }

        cout << endl;
    }

    return 0;
}
