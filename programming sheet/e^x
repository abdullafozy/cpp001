#include <iostream>

using namespace std;

// دالة لحساب e^x
double calculateExponential(double x, int n) {
    double sum = 1.0;  // المجموع التراكمي (يبدأ بالحد الأول 1)
    double term = 1.0; // قيمة الحد الحالي

    // Loop (Iteration) لحساب باقي الحدود
    for (int i = 1; i <= n; i++) {
        term *= (x / i); // تحديث الحد الحالي
        sum += term;     // إضافته للمجموع الكلي
    }

    return sum;
}

int main() {
    double x;
    int n; // عدد الحدود (Iterations) - كلما زاد العدد زادت الدقة (Accuracy)
    
    cout << "Enter the value of x: ";
    cin >> x;
    cout << "Enter the number of terms (n): ";
    cin >> n;

    cout << "e^" << x << " = " << calculateExponential(x, n) << endl;

    return 0;
}
