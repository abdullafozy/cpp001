#include <iostream>

using namespace std;

// دالة لحساب sin(x)
double calculateSin(double x, int n) {
    double sum = x;   // المجموع التراكمي (يبدأ بالحد الأول x)
    double term = x;  // قيمة الحد الحالي

    // Loop (Iteration) لحساب باقي الحدود
    for (int i = 1; i < n; i++) {
        // تحديث الحد الحالي بناءً على الحد السابق
        term = term * (-1 * x * x) / ((2 * i) * (2 * i + 1));
        sum += term; // إضافته للمجموع الكلي
    }

    return sum;
}

int main() {
    double x;
    int n; 
    
    cout << "Enter the value of x: ";
    cin >> x;
    cout << "Enter the number of terms (n): ";
    cin >> n;

    cout << "sin(" << x << ") = " << calculateSin(x, n) << endl;

    return 0;
}
