#include <iostream>
using namespace std;
#include<cctype>
#include<string>
bool isvowel(char c){
     c=tolower(c);
    return (c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u');
}
void removee(string s){
    for(int i=0 ;i<s.size() ;i++){
        if( isvowel(s[i]) ){
// دمج النص قبل وبعد الحرف المستهدف
 s.substr(0, i) → بياخد الجزء من أول الكلمة لحد قبل الحرف اللي هنحذفه
s.substr(i + 1) →   بياخد الجزء بعد الحرف ده لغاية اخر الكلمة
s = s.substr(0, i) + s.substr(i + 1);
            // تقليل المؤشر لتعويض تقلص طول النص
            i--;
// ex: s = "aei"
أول لفة:
i = 0 → نحذف 'a'
تبقى "ei"
لو ما عملناش i--:
i هتبقى 1
يبقى هنفحص 'i' ونسيب 'e' 😬
لكن مع i--:
بعد الحذف: i-- → يرجع لـ -1
وبعدين اللوب تزوده → يبقى 0
كده نرجع نفحص 'e' ✔️
        }
    }
    cout<<s;
}
int main()
{ 
    string s;
    cin>>s;
    removee(s);

    return 0 ;
}
